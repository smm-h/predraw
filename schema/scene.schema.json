{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://predraw.dev/schema/scene.schema.json",
  "title": "Predraw Scene",
  "description": "A predraw scene file defining a vector graphic composition.",
  "type": "object",
  "required": ["width", "height", "elements"],
  "properties": {
    "width": {
      "type": "number",
      "description": "Canvas width in pixels."
    },
    "height": {
      "type": "number",
      "description": "Canvas height in pixels."
    },
    "background": {
      "type": "string",
      "description": "Default background color (CSS color or $ref)."
    },
    "styles": {
      "type": "object",
      "description": "Named style tokens with light/dark variants. Referenced via $name in fill values.",
      "additionalProperties": {
        "$ref": "#/$defs/style"
      }
    },
    "imports": {
      "type": "object",
      "description": "Mapping of alias names to relative file paths for external component definitions.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "defs": {
      "type": "object",
      "description": "Inline component definitions (packed format). Each key is a reusable component name.",
      "additionalProperties": {
        "$ref": "#/$defs/element"
      }
    },
    "elements": {
      "type": "array",
      "description": "Ordered list of elements to render.",
      "items": {
        "$ref": "#/$defs/element"
      }
    },
    "pipeline": {
      "type": "array",
      "description": "Post-processing steps applied after initial layout.",
      "items": {
        "$ref": "#/$defs/pipelineStep"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "style": {
      "type": "object",
      "description": "A style token with light and dark mode color values.",
      "required": ["light", "dark"],
      "properties": {
        "light": {
          "type": "string",
          "description": "Color value for light mode."
        },
        "dark": {
          "type": "string",
          "description": "Color value for dark mode."
        }
      },
      "additionalProperties": false
    },
    "transform": {
      "type": "object",
      "description": "2D transform with translate and scale.",
      "properties": {
        "translate": {
          "type": "array",
          "description": "Translation as [x, y].",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "default": [0.0, 0.0]
        },
        "scale": {
          "type": "array",
          "description": "Scale as [sx, sy].",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "default": [1.0, 1.0]
        }
      },
      "additionalProperties": false
    },
    "font": {
      "type": "object",
      "description": "Font specification for text elements.",
      "required": ["family", "size"],
      "properties": {
        "family": {
          "type": "string",
          "description": "Font family (CSS font-family syntax)."
        },
        "size": {
          "type": "number",
          "description": "Font size in pixels."
        },
        "weight": {
          "type": "integer",
          "description": "Font weight (100-900).",
          "minimum": 100,
          "maximum": 900,
          "default": 400
        }
      },
      "additionalProperties": false
    },
    "charStyle": {
      "type": "object",
      "description": "Per-character styling override for text elements.",
      "required": ["chars"],
      "properties": {
        "chars": {
          "type": "string",
          "description": "Characters to match for this style."
        },
        "opacity": {
          "type": "number",
          "description": "Opacity for matched characters.",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "fill": {
          "type": "string",
          "description": "Fill color for matched characters (CSS color or $ref)."
        }
      },
      "additionalProperties": false
    },
    "element": {
      "description": "A drawable element. The type field determines which properties are relevant.",
      "oneOf": [
        { "$ref": "#/$defs/backgroundElement" },
        { "$ref": "#/$defs/rectElement" },
        { "$ref": "#/$defs/pathElement" },
        { "$ref": "#/$defs/textElement" },
        { "$ref": "#/$defs/groupElement" },
        { "$ref": "#/$defs/useElement" }
      ]
    },
    "backgroundElement": {
      "type": "object",
      "description": "Fills the entire canvas with a color.",
      "required": ["type", "fill"],
      "properties": {
        "type": {
          "const": "background"
        },
        "id": {
          "type": "string"
        },
        "fill": {
          "type": "string",
          "description": "Fill color (CSS color or $ref)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      },
      "additionalProperties": false
    },
    "rectElement": {
      "type": "object",
      "description": "A rectangle element.",
      "required": ["type"],
      "properties": {
        "type": {
          "const": "rect"
        },
        "id": {
          "type": "string"
        },
        "x": {
          "type": "number",
          "default": 0
        },
        "y": {
          "type": "number",
          "default": 0
        },
        "width": {
          "type": "number",
          "default": 0
        },
        "height": {
          "type": "number",
          "default": 0
        },
        "fill": {
          "type": "string",
          "description": "Fill color (CSS color or $ref)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      },
      "additionalProperties": false
    },
    "pathElement": {
      "type": "object",
      "description": "An SVG path element.",
      "required": ["type", "d"],
      "properties": {
        "type": {
          "const": "path"
        },
        "id": {
          "type": "string"
        },
        "d": {
          "type": "string",
          "description": "SVG path data string."
        },
        "fill": {
          "type": "string",
          "description": "Fill color (CSS color or $ref)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      },
      "additionalProperties": false
    },
    "textElement": {
      "type": "object",
      "description": "A text element with font and optional per-character styling.",
      "required": ["type", "content"],
      "properties": {
        "type": {
          "const": "text"
        },
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "description": "Text content to render."
        },
        "x": {
          "type": "number",
          "default": 0
        },
        "y": {
          "type": "number",
          "default": 0
        },
        "anchor": {
          "type": "string",
          "description": "Text anchor alignment.",
          "enum": ["start", "middle", "end"],
          "default": "start"
        },
        "fill": {
          "type": "string",
          "description": "Fill color (CSS color or $ref)."
        },
        "font": {
          "$ref": "#/$defs/font"
        },
        "letterSpacing": {
          "type": "number",
          "description": "Letter spacing in pixels.",
          "default": 0
        },
        "letter_spacing": {
          "type": "number",
          "description": "Letter spacing (snake_case alias).",
          "default": 0
        },
        "charStyles": {
          "type": "array",
          "description": "Per-character style overrides.",
          "items": {
            "$ref": "#/$defs/charStyle"
          }
        },
        "char_styles": {
          "type": "array",
          "description": "Per-character style overrides (snake_case alias).",
          "items": {
            "$ref": "#/$defs/charStyle"
          }
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      },
      "additionalProperties": false
    },
    "groupElement": {
      "type": "object",
      "description": "A group containing child elements.",
      "required": ["type"],
      "properties": {
        "type": {
          "const": "group"
        },
        "id": {
          "type": "string"
        },
        "elements": {
          "type": "array",
          "description": "Child elements in this group.",
          "items": {
            "$ref": "#/$defs/element"
          }
        },
        "children": {
          "type": "array",
          "description": "Child elements (alias for elements).",
          "items": {
            "$ref": "#/$defs/element"
          }
        },
        "fill": {
          "type": "string",
          "description": "Fill color inherited by children (CSS color or $ref)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      },
      "additionalProperties": false
    },
    "useElement": {
      "type": "object",
      "description": "Instantiates a component from defs or imports by name.",
      "required": ["use"],
      "properties": {
        "type": {
          "const": "use"
        },
        "id": {
          "type": "string"
        },
        "use": {
          "type": "string",
          "description": "Name of the def/import to instantiate."
        },
        "fill": {
          "type": "string",
          "description": "Fill color override (CSS color or $ref)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      },
      "additionalProperties": false
    },
    "pipelineStep": {
      "description": "A post-processing pipeline step.",
      "oneOf": [
        { "$ref": "#/$defs/centerStep" },
        { "$ref": "#/$defs/placeStep" },
        { "$ref": "#/$defs/groupStep" },
        { "$ref": "#/$defs/textToPathsStep" }
      ]
    },
    "centerStep": {
      "type": "object",
      "description": "Centers an element on the canvas.",
      "required": ["action", "target"],
      "properties": {
        "action": {
          "const": "center"
        },
        "target": {
          "type": "string",
          "description": "ID of the element to center."
        },
        "axis": {
          "type": "string",
          "description": "Which axis to center on.",
          "enum": ["x", "y", "both"],
          "default": "both"
        }
      },
      "additionalProperties": false
    },
    "placeStep": {
      "type": "object",
      "description": "Places an element below another with an optional gap.",
      "required": ["action", "target", "below"],
      "properties": {
        "action": {
          "const": "place"
        },
        "target": {
          "type": "string",
          "description": "ID of the element to place."
        },
        "below": {
          "type": "string",
          "description": "ID of the reference element to place below."
        },
        "gap": {
          "type": "number",
          "description": "Gap in pixels between the elements.",
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "groupStep": {
      "type": "object",
      "description": "Groups multiple elements into a new group element.",
      "required": ["action", "targets", "id"],
      "properties": {
        "action": {
          "const": "group"
        },
        "targets": {
          "type": "array",
          "description": "IDs of elements to group together.",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string",
          "description": "ID to assign to the new group."
        }
      },
      "additionalProperties": false
    },
    "textToPathsStep": {
      "type": "object",
      "description": "Converts a text element to path outlines.",
      "required": ["action", "target"],
      "properties": {
        "action": {
          "const": "text-to-paths"
        },
        "target": {
          "type": "string",
          "description": "ID of the text element to convert."
        }
      },
      "additionalProperties": false
    }
  }
}
