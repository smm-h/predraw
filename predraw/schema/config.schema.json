{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://predraw.dev/schema/config.schema.json",
  "title": "Predraw Config",
  "description": "Configuration file for predraw output settings.",
  "type": "object",
  "required": ["outputs"],
  "properties": {
    "outputs": {
      "type": "array",
      "description": "List of output render targets.",
      "items": {
        "$ref": "#/$defs/output"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "output": {
      "type": "object",
      "description": "A single output render target specifying format, path, and rendering options.",
      "required": ["format", "path"],
      "properties": {
        "format": {
          "type": "string",
          "description": "Output image format.",
          "enum": ["svg", "png", "webp"]
        },
        "path": {
          "type": "string",
          "description": "Output file path (relative to the project directory)."
        },
        "mode": {
          "type": "string",
          "description": "Color mode for style resolution.",
          "enum": ["light", "dark"]
        },
        "quality": {
          "type": "integer",
          "description": "Compression quality (applicable to lossy formats like webp).",
          "minimum": 1,
          "maximum": 100
        }
      },
      "additionalProperties": false
    }
  }
}
